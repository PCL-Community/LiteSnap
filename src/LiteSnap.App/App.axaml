<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.Styling"
             x:Class="LiteSnap.App.App"
             xmlns:local="using:LiteSnap.App"
             xmlns:conv="using:LiteSnap.App.Converters"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <!-- ── Converters ── -->
            <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <conv:FileSizeConverter x:Key="FileSizeConverter"/>
            <conv:BoolToIconConverter x:Key="BoolToIconConverter"/>

            <!-- ── Core Colors ── -->
            <Color x:Key="AccentColor">#60CDE0</Color>
            <Color x:Key="AccentDarkColor">#4DB8CC</Color>
            <Color x:Key="PageBackground">#1A1A1A</Color>
            <Color x:Key="CardBackground">#252525</Color>
            <Color x:Key="ToolbarBackground">#2D2D2D</Color>
            <Color x:Key="SubtleBorder">#3D3D3D</Color>
            <Color x:Key="PrimaryText">#FFFFFF</Color>
            <Color x:Key="SecondaryText">#9A9A9A</Color>
            <Color x:Key="TertiaryText">#6B6B6B</Color>

            <!-- ── Brushes ── -->
            <SolidColorBrush x:Key="PageBackgroundBrush" Color="{StaticResource PageBackground}"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
            <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="{StaticResource ToolbarBackground}"/>
            <SolidColorBrush x:Key="SubtleBorderBrush" Color="{StaticResource SubtleBorder}"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryText}"/>
            <SolidColorBrush x:Key="TertiaryTextBrush" Color="{StaticResource TertiaryText}"/>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>

            <!-- ── Icons (Material Design) ── -->
            <StreamGeometry x:Key="IconFolder">M10 4H4c-1.11 0-2 .89-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-8z</StreamGeometry>
            <StreamGeometry x:Key="IconWrench">m21.71 20.29l-1.42 1.42a1 1 0 0 1-1.41 0L7 9.85A3.8 3.8 0 0 1 6 10a4 4 0 0 1-3.78-5.3l2.54 2.54l.53-.53l1.42-1.42l.53-.53L4.7 2.22A4 4 0 0 1 10 6a3.8 3.8 0 0 1-.15 1l11.86 11.88a1 1 0 0 1 0 1.41M2.29 18.88a1 1 0 0 0 0 1.41l1.42 1.42a1 1 0 0 0 1.41 0l5.47-5.46l-2.83-2.83M20 2l-4 2v2l-2.17 2.17l2 2L18 8h2l2-4Z</StreamGeometry>
