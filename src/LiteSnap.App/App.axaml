            <StreamGeometry x:Key="IconCheck">M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z</StreamGeometry>
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <fa:FluentAvaloniaTheme
            PreferSystemTheme="False"
            PreferUserAccentColor="False"
            UseSystemFontOnWindows="True" />
    </Application.Styles>
</Application>
