<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LiteSnap.App.App"
             xmlns:local="using:LiteSnap.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <!-- ── Core Colors ── -->
            <Color x:Key="AccentColor">#60CDE0</Color>
            <Color x:Key="AccentDarkColor">#4DB8CC</Color>
            <Color x:Key="PageBackground">#1A1A1A</Color>
            <Color x:Key="CardBackground">#252525</Color>
            <Color x:Key="ToolbarBackground">#2D2D2D</Color>
            <Color x:Key="SubtleBorder">#3D3D3D</Color>
            <Color x:Key="PrimaryText">#FFFFFF</Color>
            <Color x:Key="SecondaryText">#9A9A9A</Color>
            <Color x:Key="TertiaryText">#6B6B6B</Color>

            <!-- ── Brushes ── -->
            <SolidColorBrush x:Key="PageBackgroundBrush" Color="{StaticResource PageBackground}"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
            <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="{StaticResource ToolbarBackground}"/>
            <SolidColorBrush x:Key="SubtleBorderBrush" Color="{StaticResource SubtleBorder}"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryText}"/>
            <SolidColorBrush x:Key="TertiaryTextBrush" Color="{StaticResource TertiaryText}"/>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}"/>
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <!-- ── Global Styles ── -->
        <Style Selector="Button.ToolbarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.ToolbarButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3FFFFFFF"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.ToolbarButton:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#28FFFFFF"/>
        </Style>
        <Style Selector="Button.ToolbarButton:disabled">
            <Setter Property="Opacity" Value="0.35"/>
        </Style>

        <Style Selector="Button.PrimaryButton">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.PrimaryButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentDarkBrush}"/>
        </Style>

        <Style Selector="ListBox.FlatList">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style Selector="ListBox.FlatList ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="ListBox.FlatList ListBoxItem:pointerover">
            <Setter Property="Background" Value="#0FFFFFFF"/>
        </Style>

        <!-- Accent bar: lights up on selection -->
        <Style Selector="ListBox.FlatList ListBoxItem:selected Border.AccentBar">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="ListBox.FlatList ListBoxItem:pointerover Border.AccentBar">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>
        <Style Selector="Border.AccentBar">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Application.Styles>
</Application>
