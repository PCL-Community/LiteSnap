<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LiteSnap.App.ViewModels"
        xmlns:models="using:LiteSnap.Core.Models"
        xmlns:local="using:LiteSnap.App"
        xmlns:services="using:LiteSnap.App.Services"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="LiteSnap.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Background="{StaticResource PageBackgroundBrush}"
        Title="{local:Language Key=App.Title}"
        MinWidth="800" MinHeight="500">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ══════ CommandBar ══════ -->
        <Border Grid.Row="0" Background="{StaticResource ToolbarBackgroundBrush}">
            <DockPanel Margin="6,4">
                <StackPanel Orientation="Horizontal" Spacing="2" DockPanel.Dock="Left">
                    <!-- ── 打开 ── -->
                    <Button x:Name="OpenMenuButton" Background="Transparent" BorderThickness="0" Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Data="{StaticResource IconFolder}" Fill="{StaticResource PrimaryText}"
                                  Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="{local:Language Key=Menu.Open}" FontSize="12"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Command="{Binding OpenFolderCommand}">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconFolder}" Fill="{StaticResource PrimaryText}"
                                              Width="16" Height="16" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                    <MenuItem.Header>
                                        <TextBlock Text="{local:Language Key=Menu.OpenFolder}"/>
                                    </MenuItem.Header>
                                </MenuItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource SubtleBorderBrush}" Margin="4,6,2,6"
                               VerticalAlignment="Center"/>

                    <!-- ── 操作 ── -->
                    <Button Background="Transparent" BorderThickness="0" Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Data="{StaticResource IconWrench}" Fill="{StaticResource PrimaryText}"
                                  Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="{local:Language Key=Menu.Operations}" FontSize="12"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Command="{Binding CreateVersionCommand}"
                                          IsEnabled="{Binding IsFolderLoaded}">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconPlus}" Fill="{StaticResource PrimaryText}"
                                              Width="16" Height="16" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                    <MenuItem.Header><TextBlock Text="{local:Language Key=Menu.Create}"/></MenuItem.Header>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Command="{Binding ApplyVersionCommand}"
                                          IsEnabled="{Binding HasSelection}">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconAppWindow}" Fill="{StaticResource PrimaryText}"
                                              Width="16" Height="16" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                    <MenuItem.Header><TextBlock Text="{local:Language Key=Menu.Apply}"/></MenuItem.Header>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Command="{Binding ExportZipCommand}"
                                          IsEnabled="{Binding HasSelection}">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconExport}" Fill="{StaticResource PrimaryText}"
                                              Width="16" Height="16" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                    <MenuItem.Header><TextBlock Text="{local:Language Key=Menu.ExportZip}"/></MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding ExportFolderCommand}"
                                          IsEnabled="{Binding HasSelection}">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconFolder}" Fill="{StaticResource PrimaryText}"
                                              Width="16" Height="16" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                    <MenuItem.Header><TextBlock Text="{local:Language Key=Menu.ExportFolder}"/></MenuItem.Header>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Command="{Binding DeleteVersionCommand}"
                                          IsEnabled="{Binding HasSelection}">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconDelete}" Fill="{StaticResource PrimaryText}"
                                              Width="16" Height="16" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                    <MenuItem.Header><TextBlock Text="{local:Language Key=Menu.Delete}"/></MenuItem.Header>
                                </MenuItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource SubtleBorderBrush}" Margin="4,6,2,6"
                               VerticalAlignment="Center"/>

                    <!-- ── 设置 ── -->
                    <Button Background="Transparent" BorderThickness="0" Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Data="{StaticResource IconSettings}" Fill="{StaticResource PrimaryText}"
                                  Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="{local:Language Key=Menu.Language}" FontSize="12"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Command="{Binding SetLanguageAutoCommand}">
                                    <MenuItem.Header>
                                        <TextBlock Text="{local:Language Key=Menu.LangAuto}"/>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding SetLanguageZhCommand}">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconCheck}" Fill="{StaticResource AccentBrush}"
                                              Width="16" Height="16" Stretch="Uniform"
                                              IsVisible="{Binding Source={x:Static services:LanguageManager.Instance}, Path=IsZh}"/>
                                    </MenuItem.Icon>
                                    <MenuItem.Header>
                                        <TextBlock Text="{local:Language Key=Menu.LangZh}"/>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding SetLanguageEnCommand}">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconCheck}" Fill="{StaticResource AccentBrush}"
                                              Width="16" Height="16" Stretch="Uniform"
                                              IsVisible="{Binding Source={x:Static services:LanguageManager.Instance}, Path=IsEn}"/>
                                    </MenuItem.Icon>
                                    <MenuItem.Header>
                                        <TextBlock Text="{local:Language Key=Menu.LangEn}"/>
                                    </MenuItem.Header>
                                </MenuItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource SubtleBorderBrush}" Margin="4,6,2,6"
                               VerticalAlignment="Center"/>

                    <!-- ── 关于 ── -->
                    <Button Background="Transparent" BorderThickness="0" Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Data="{StaticResource IconInfo}" Fill="{StaticResource PrimaryText}"
                                  Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="{local:Language Key=Menu.About}" FontSize="12"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Command="{Binding CheckUpdatesCommand}">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconRefresh}" Fill="{StaticResource PrimaryText}"
                                              Width="16" Height="16" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                    <MenuItem.Header><TextBlock Text="{local:Language Key=Menu.CheckUpdates}"/></MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding OpenLicenseCommand}">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconCertificate}" Fill="{StaticResource PrimaryText}"
                                              Width="16" Height="16" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                    <MenuItem.Header><TextBlock Text="{local:Language Key=Menu.License}"/></MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding SoftwareInfoCommand}">
                                    <MenuItem.Icon>
                                        <Path Data="{StaticResource IconInfo}" Fill="{StaticResource PrimaryText}"
                                              Width="16" Height="16" Stretch="Uniform"/>
                                    </MenuItem.Icon>
                                    <MenuItem.Header><TextBlock Text="{local:Language Key=Menu.SoftwareInfo}"/></MenuItem.Header>
                                </MenuItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10" DockPanel.Dock="Right"
                            IsVisible="{Binding IsLoading}" VerticalAlignment="Center" Margin="0,0,8,0">
                    <ProgressBar IsIndeterminate="True" Width="100" Height="3" Background="#3FFFFFFF"
                                 Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="{local:Language Key=Status.Processing}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════ Accent Separator ══════ -->
        <Rectangle Grid.Row="1" Fill="{StaticResource AccentBrush}" Height="2" Opacity="0.8"/>

        <!-- ══════ Main Content ══════ -->
        <Grid Grid.Row="2" ColumnDefinitions="320,*" Margin="0,0,0,0">

            <!-- ─── 左侧: 版本列表 ─── -->
            <Border Grid.Column="0" Margin="12,12,6,12" CornerRadius="8"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="16,14,16,8">
                        <TextBlock Text="{local:Language Key=Snapshot.Section}" FontSize="16" FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryText}" VerticalAlignment="Center"/>
                    </Grid>

                    <ListBox ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion}"
                             Classes="FlatList" Margin="0,4,0,4">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:VersionData">
                                <Grid ColumnDefinitions="3,*" Margin="0,2">
                                    <Border Classes="AccentBar" CornerRadius="2"
                                            Width="3" HorizontalAlignment="Stretch"/>
                                    <Border Grid.Column="1" Padding="12,10" CornerRadius="4">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Desc}" FontSize="11"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                            <TextBlock Text="{Binding Created, StringFormat='{}{0:G}'}"
                                                       FontSize="10" Foreground="{StaticResource TertiaryTextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ─── 右侧: 快照详情 + 文件列表 ─── -->
            <Border Grid.Column="1" Margin="6,12,12,12" CornerRadius="8"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,*">
                    <DockPanel Grid.Row="0" Margin="0" IsVisible="{Binding HasSelection}">

                        <!-- 信息条 -->
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource ToolbarBackgroundBrush}"
                                CornerRadius="8,8,0,0" Padding="16,14">
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{local:Language Key=Field.Name}" FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"/>
                                    <TextBlock Text="{Binding SelectedVersion.Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryText}"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{local:Language Key=Field.Files}" FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"/>
                                    <TextBlock FontSize="14" Foreground="{StaticResource PrimaryText}">
                                        <Run Text="{Binding FileCount}"/><Run Text="{local:Language Key=Field.FilesSuffix}"/>
                                        <Run Text="{local:Language Key=Field.Separator}"/><Run Text="{Binding FolderCount}"/><Run Text="{local:Language Key=Field.FoldersSuffix}"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{local:Language Key=Field.Size}" FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"/>
                                    <TextBlock Text="{Binding TotalSizeFormatted}" FontSize="14"
                                               Foreground="{StaticResource PrimaryText}"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{local:Language Key=Field.Created}" FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"/>
                                    <TextBlock Text="{Binding SelectedVersion.Created, StringFormat='{}{0:G}'}"
                                               FontSize="13" Foreground="{StaticResource PrimaryText}"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{local:Language Key=Field.Description}" FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"/>
                                    <TextBlock Text="{Binding SelectedVersion.Desc}"
                                               FontSize="13" Foreground="{StaticResource PrimaryText}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </DockPanel>

                    <!-- ══════ 操作按钮 ══════ -->
                    <Border Grid.Row="1" BorderBrush="{StaticResource SubtleBorderBrush}"
                            BorderThickness="0,0,0,1" Padding="14,8" IsVisible="{Binding HasSelection}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Background="{StaticResource AccentBrush}" BorderThickness="0"
                                    Foreground="White" Padding="12,5" CornerRadius="4"
                                    Command="{Binding ApplyVersionCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Path Data="{StaticResource IconAppWindow}" Fill="White"
                                          Width="14" Height="14" Stretch="Uniform"/>
                                    <TextBlock Text="{local:Language Key=Action.Apply}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Background="#3FFFFFFF" BorderThickness="0"
                                    Foreground="White" Padding="12,5" CornerRadius="4"
                                    Command="{Binding ExportZipCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Path Data="{StaticResource IconExport}" Fill="White"
                                          Width="14" Height="14" Stretch="Uniform"/>
                                    <TextBlock Text="{local:Language Key=Action.ZIP}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Background="#3FFFFFFF" BorderThickness="0"
                                    Foreground="White" Padding="12,5" CornerRadius="4"
                                    Command="{Binding ExportFolderCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Path Data="{StaticResource IconFolder}" Fill="White"
                                          Width="14" Height="14" Stretch="Uniform"/>
                                    <TextBlock Text="{local:Language Key=Action.Folder}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Background="#44CC6666" BorderThickness="0"
                                    Foreground="White" Padding="12,5" CornerRadius="4"
                                    Command="{Binding DeleteVersionCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Path Data="{StaticResource IconDelete}" Fill="White"
                                          Width="14" Height="14" Stretch="Uniform"/>
                                    <TextBlock Text="{local:Language Key=Action.Delete}" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 文件树 -->
                    <TreeView Grid.Row="2" IsVisible="{Binding HasSelection}"
                              ItemsSource="{Binding FileTreeRoot}" Margin="0,4,0,4"
                              BorderThickness="0" Background="Transparent">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate x:DataType="models:FileTreeNode"
                                              ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,4">
                                    <Path Data="{Binding IsDirectory, Converter={StaticResource BoolToIconConverter}}"
                                          Width="16" Height="16" Stretch="Uniform"
                                          Fill="{StaticResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                               Foreground="{StaticResource PrimaryText}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Length, Converter={StaticResource FileSizeConverter}}"
                                               FontSize="11"
                                               Foreground="{StaticResource TertiaryTextBrush}"
                                               Margin="16,0,0,0"/>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <!-- 未选择时占位 -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="3" Text="{local:Language Key=Snapshot.SelectHint}" FontSize="16"
                               Foreground="{StaticResource TertiaryTextBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               IsVisible="{Binding HasSelection, Converter={StaticResource InverseBoolConverter}}"/>
                </Grid>
            </Border>

        </Grid>

        <!-- ══════ StatusBar ══════ -->
        <Border Grid.Row="3" Background="{StaticResource ToolbarBackgroundBrush}"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource SubtleBorderBrush}">
            <Grid Margin="14,5,14,5" ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" FontSize="12" VerticalAlignment="Center"
                           Foreground="{StaticResource TertiaryTextBrush}" Margin="0,0,16,0"
                           IsVisible="{Binding IsFolderLoaded}">
                    <Run Text="{Binding Versions.Count}"/><Run Text="{local:Language Key=Field.SnapshotsSuffix}"/>
                </TextBlock>
                <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center"
                           Foreground="{StaticResource TertiaryTextBrush}"
                           IsVisible="{Binding IsFolderLoaded}">
                    <Run Text="{Binding FileCount}"/><Run Text="{local:Language Key=Field.FilesSuffix}"/>
                </TextBlock>
            </Grid>
        </Border>

    </Grid>
</Window>
