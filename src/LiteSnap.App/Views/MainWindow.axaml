<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LiteSnap.App.ViewModels"
        xmlns:models="using:LiteSnap.Core.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="LiteSnap.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Background="{StaticResource PageBackgroundBrush}"
        Title="LiteSnap 快照管理器"
        MinWidth="800" MinHeight="500">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ══════ CommandBar ══════ -->
        <Border Grid.Row="0" Background="{StaticResource ToolbarBackgroundBrush}">
            <DockPanel Margin="6,4">
                <StackPanel Orientation="Horizontal" Spacing="2" DockPanel.Dock="Left">
                    <!-- ── 打开 ── -->
                    <Button x:Name="OpenMenuButton" Background="Transparent" BorderThickness="0" Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="📂" FontSize="14"/>
                            <TextBlock Text="打开" FontSize="12"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="📂 打开文件夹" Command="{Binding OpenFolderCommand}"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource SubtleBorderBrush}" Margin="4,6,2,6"
                               VerticalAlignment="Center"/>

                    <!-- ── 操作 ── -->
                    <Button Background="Transparent" BorderThickness="0" Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="⚙" FontSize="14"/>
                            <TextBlock Text="操作" FontSize="12"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="➕ 创建" Command="{Binding CreateVersionCommand}"
                                          IsEnabled="{Binding IsFolderLoaded}"/>
                                <Separator/>
                                <MenuItem Header="↩ 应用" Command="{Binding ApplyVersionCommand}"
                                          IsEnabled="{Binding HasSelection}"/>
                                <Separator/>
                                <MenuItem Header="📦 导出 ZIP" Command="{Binding ExportZipCommand}"
                                          IsEnabled="{Binding HasSelection}"/>
                                <MenuItem Header="📁 导出文件夹" Command="{Binding ExportFolderCommand}"
                                          IsEnabled="{Binding HasSelection}"/>
                                <Separator/>
                                <MenuItem Header="🗑 删除" Command="{Binding DeleteVersionCommand}"
                                          IsEnabled="{Binding HasSelection}"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource SubtleBorderBrush}" Margin="4,6,2,6"
                               VerticalAlignment="Center"/>

                    <!-- ── 关于 ── -->
                    <Button Background="Transparent" BorderThickness="0" Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="ⓘ" FontSize="14"/>
                            <TextBlock Text="关于" FontSize="12"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="🔄 检查更新" Command="{Binding CheckUpdatesCommand}"/>
                                <MenuItem Header="📄 开源许可" Command="{Binding OpenLicenseCommand}"/>
                                <MenuItem Header="ℹ️ 软件信息" Command="{Binding SoftwareInfoCommand}"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10" DockPanel.Dock="Right"
                            IsVisible="{Binding IsLoading}" VerticalAlignment="Center" Margin="0,0,8,0">
                    <ProgressBar IsIndeterminate="True" Width="100" Height="3" Background="#3FFFFFFF"
                                 Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="处理中..." FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════ Accent Separator ══════ -->
        <Rectangle Grid.Row="1" Fill="{StaticResource AccentBrush}" Height="2" Opacity="0.8"/>

        <!-- ══════ Main Content ══════ -->
        <Grid Grid.Row="2" ColumnDefinitions="320,*" Margin="0,0,0,0">

            <!-- ─── 左侧: 版本列表 ─── -->
            <Border Grid.Column="0" Margin="12,12,6,12" CornerRadius="8"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="16,14,16,8">
                        <TextBlock Text="快照" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryText}" VerticalAlignment="Center"/>
                    </Grid>

                    <ListBox ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion}"
                             Classes="FlatList" Margin="0,4,0,4">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:VersionData">
                                <Grid ColumnDefinitions="3,*" Margin="0,2">
                                    <Border Classes="AccentBar" CornerRadius="2"
                                            Width="3" HorizontalAlignment="Stretch"/>
                                    <Border Grid.Column="1" Padding="12,10" CornerRadius="4">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Desc}" FontSize="11"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                            <TextBlock Text="{Binding Created, StringFormat='{}{0:G}'}"
                                                       FontSize="10" Foreground="{StaticResource TertiaryTextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ─── 右侧: 快照详情 + 文件列表 ─── -->
            <Border Grid.Column="1" Margin="6,12,12,12" CornerRadius="8"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource SubtleBorderBrush}" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,*">
                    <DockPanel Grid.Row="0" Margin="0" IsVisible="{Binding HasSelection}">

                        <!-- 信息条: 名称 文件数 大小 创建时间 备注 -->
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource ToolbarBackgroundBrush}"
                                CornerRadius="8,8,0,0" Padding="16,14">
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="名称" FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"/>
                                    <TextBlock Text="{Binding SelectedVersion.Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryText}"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="文件数" FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"/>
                                    <TextBlock FontSize="14" Foreground="{StaticResource PrimaryText}">
                                        <Run Text="{Binding FileCount}"/><Run Text=" 个文件"/>
                                        <Run Text=", "/><Run Text="{Binding FolderCount}"/><Run Text=" 个目录"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="大小" FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"/>
                                    <TextBlock Text="{Binding TotalSizeFormatted}" FontSize="14"
                                               Foreground="{StaticResource PrimaryText}"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="创建时间" FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"/>
                                    <TextBlock Text="{Binding SelectedVersion.Created, StringFormat='{}{0:G}'}"
                                               FontSize="13" Foreground="{StaticResource PrimaryText}"/>
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="备注" FontSize="10"
                                               Foreground="{StaticResource TertiaryTextBrush}"/>
                                    <TextBlock Text="{Binding SelectedVersion.Desc}"
                                               FontSize="13" Foreground="{StaticResource PrimaryText}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </DockPanel>

                    <!-- ══════ 操作按钮 ══════ -->
                    <Border Grid.Row="1" BorderBrush="{StaticResource SubtleBorderBrush}"
                            BorderThickness="0,0,0,1" Padding="14,8" IsVisible="{Binding HasSelection}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Background="{StaticResource AccentBrush}" BorderThickness="0"
                                    Foreground="White" Padding="12,5" CornerRadius="4"
                                    Command="{Binding ApplyVersionCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="↩" FontSize="12"/>
                                    <TextBlock Text="应用" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Background="#3FFFFFFF" BorderThickness="0"
                                    Foreground="White" Padding="12,5" CornerRadius="4"
                                    Command="{Binding ExportZipCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="📦" FontSize="12"/>
                                    <TextBlock Text="导出 ZIP" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Background="#3FFFFFFF" BorderThickness="0"
                                    Foreground="White" Padding="12,5" CornerRadius="4"
                                    Command="{Binding ExportFolderCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="📁" FontSize="12"/>
                                    <TextBlock Text="导出文件夹" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Background="#44CC6666" BorderThickness="0"
                                    Foreground="White" Padding="12,5" CornerRadius="4"
                                    Command="{Binding DeleteVersionCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="🗑" FontSize="12"/>
                                    <TextBlock Text="删除" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 文件列表区域 -->
                    <Grid Grid.Row="2" IsVisible="{Binding HasSelection}"
                          RowDefinitions="Auto,*" Margin="0">

                        <!-- 列头 -->
                        <Border Grid.Row="0" BorderBrush="{StaticResource SubtleBorderBrush}"
                                BorderThickness="0,0,0,1" Padding="16,10,16,8">
                            <Grid ColumnDefinitions="80,1*,100">
                                <TextBlock Grid.Column="0" Text="类型" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBlock Grid.Column="1" Text="名称" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBlock Grid.Column="2" Text="大小" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- 文件行 -->
                        <ListBox Grid.Row="1" ItemsSource="{Binding NodeFiles}"
                                 Classes="FlatList" Margin="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:FileVersionObjects">
                                    <Border BorderBrush="{StaticResource SubtleBorderBrush}"
                                            BorderThickness="0,0,0,0" Padding="16,8,16,8">
                                        <Grid ColumnDefinitions="80,1*,100" VerticalAlignment="Center">
                                            <Border Grid.Column="0" Padding="5,2" CornerRadius="3"
                                                    Background="#18FFFFFF" BorderThickness="0" MinWidth="50"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding ObjectType}" FontSize="11"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Path}" FontSize="12"
                                                       Foreground="{StaticResource PrimaryText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" FontSize="12"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       HorizontalAlignment="Right"
                                                       Text="{Binding Converter={StaticResource FileSizeConverter}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </Grid>

                    <!-- 未选择时占位 -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="3" Text="请选择一个快照" FontSize="16"
                               Foreground="{StaticResource TertiaryTextBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               IsVisible="{Binding HasSelection, Converter={StaticResource InverseBoolConverter}}"/>
                </Grid>
            </Border>

        </Grid>

        <!-- ══════ StatusBar ══════ -->
        <Border Grid.Row="3" Background="{StaticResource ToolbarBackgroundBrush}"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource SubtleBorderBrush}">
            <Grid Margin="14,5,14,5" ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" FontSize="12" VerticalAlignment="Center"
                           Foreground="{StaticResource TertiaryTextBrush}" Margin="0,0,16,0"
                           IsVisible="{Binding IsFolderLoaded}">
                    <Run Text="{Binding Versions.Count}"/><Run Text=" 个快照"/>
                </TextBlock>
                <TextBlock Grid.Column="3" FontSize="12" VerticalAlignment="Center"
                           Foreground="{StaticResource TertiaryTextBrush}"
                           IsVisible="{Binding IsFolderLoaded}">
                    <Run Text="{Binding NodeFiles.Count}"/><Run Text=" 个文件"/>
                </TextBlock>
            </Grid>
        </Border>

    </Grid>
</Window>
