<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LiteSnap.App.ViewModels"
        xmlns:models="using:LiteSnap.Core.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="LiteSnap.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="LiteSnap 快照管理器"
        MinWidth="800" MinHeight="500">

    <Grid RowDefinitions="Auto,2,*,Auto">

        <!-- ══════ Toolbar ══════ -->
        <Border Grid.Row="0" Padding="8,6" Background="{StaticResource SystemChromeMediumColor}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="4" DockPanel.Dock="Left">
                    <Button Command="{Binding OpenFolderCommand}" MinWidth="100" Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="📂" FontSize="16"/>
                            <TextBlock Text="打开文件夹" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource SystemBaseMediumLowColor}" Margin="4,2"/>

                    <Button Command="{Binding ExportZipCommand}"
                            IsEnabled="{Binding HasSelection}"
                            MinWidth="100" Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="📦" FontSize="16"/>
                            <TextBlock Text="导出 ZIP" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ExportFolderCommand}"
                            IsEnabled="{Binding HasSelection}"
                            MinWidth="110" Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="📁" FontSize="16"/>
                            <TextBlock Text="导出文件夹" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource SystemBaseMediumLowColor}" Margin="4,2"/>

                    <Button Command="{Binding ApplyVersionCommand}"
                            IsEnabled="{Binding HasSelection}"
                            MinWidth="100" Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="↩" FontSize="16"/>
                            <TextBlock Text="应用备份" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CreateVersionCommand}"
                            IsEnabled="{Binding IsFolderLoaded}"
                            MinWidth="100" Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="➕" FontSize="16"/>
                            <TextBlock Text="创建备份" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding DeleteVersionCommand}"
                            IsEnabled="{Binding HasSelection}"
                            MinWidth="100" Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="🗑" FontSize="16"/>
                            <TextBlock Text="删除备份" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Right"
                            IsVisible="{Binding IsLoading}">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text="处理中..." FontSize="12" VerticalAlignment="Center"
                               Foreground="{StaticResource SystemAccentColor}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════ Separator ══════ -->
        <Rectangle Grid.Row="1" Fill="{StaticResource SystemAccentColor}" Height="2"/>

        <!-- ══════ Status Bar ══════ -->
        <Border Grid.Row="3" Padding="12,4" Background="{StaticResource SystemChromeMediumColor}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" FontSize="11" VerticalAlignment="Center"
                           Foreground="{StaticResource SystemBaseMediumColor}">
                    <Run Text="{Binding Versions.Count}"/>
                    <Run Text="个快照"/>
                    <Run Text=" | "/>
                    <Run Text="{Binding NodeFiles.Count}"/>
                    <Run Text="个文件"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ══════ Main Content ══════ -->
        <Grid Grid.Row="2" ColumnDefinitions="320,*" Margin="0,4,0,0">

            <!-- 左侧: 版本列表 -->
            <Border Grid.Column="0" Margin="8,4,4,8" CornerRadius="6"
                    BorderBrush="{StaticResource SystemBaseLowColor}" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="快照列表" FontWeight="SemiBold" FontSize="14"
                               Padding="12,10" Foreground="{StaticResource SystemAccentColor}"/>

                    <ListBox ItemsSource="{Binding Versions}"
                             SelectedItem="{Binding SelectedVersion}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:VersionData">
                                <Border Padding="10,8" CornerRadius="4" Margin="4,1">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Desc}" FontSize="11"
                                                   Foreground="{StaticResource SystemBaseMediumColor}"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                        <TextBlock Text="{Binding Created, StringFormat='{}{0:G}'}"
                                                   FontSize="11" Foreground="{StaticResource SystemBaseMediumLowColor}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 右侧: 文件详情 -->
            <Border Grid.Column="1" Margin="4,4,8,8" CornerRadius="6"
                    BorderBrush="{StaticResource SystemBaseLowColor}" BorderThickness="1">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="12,10"
                            Background="{StaticResource SystemAccentColor}" CornerRadius="6,6,0,0">
                        <TextBlock Text="文件详情" FontWeight="SemiBold" FontSize="14" Foreground="White"/>
                    </Border>

                    <ListBox ItemsSource="{Binding NodeFiles}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:FileVersionObjects">
                                <Border Padding="8,5" Margin="4,1" CornerRadius="3">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" VerticalAlignment="Center">
                                        <Border Grid.Column="0" Margin="0,0,8,0" Padding="3,1" CornerRadius="3"
                                                BorderBrush="{StaticResource SystemBaseMediumLowColor}" BorderThickness="1">
                                            <TextBlock Text="{Binding ObjectType}" FontSize="10"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Path}"
                                                   FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Margin="12,0,6,0"
                                                   Text="{Binding Length, StringFormat='{}{0:N0}'}"
                                                   FontSize="11" Foreground="{StaticResource SystemBaseMediumColor}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Hash}"
                                                   FontSize="10" Foreground="{StaticResource SystemBaseMediumLowColor}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

        </Grid>

    </Grid>
</Window>
